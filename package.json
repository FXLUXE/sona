    "reprime": "bun run scripts/reingest-demos.ts",
    "corpus": "bun run scripts/inspect-corpus.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "hono": "^4.6.14",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
