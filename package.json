{
  "name": "ai-website-assistant",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "demo": "bun run scripts/demo.ts",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && bun run scripts/check-dashboard-js.ts",
    "eval": "bun run scripts/eval.ts",
