# ---- Storage: Supabase (FREE, no card) -> https://supabase.com ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# anon (public) key — safe for the browser; needed for the /dashboard magic-link login
SUPABASE_ANON_KEY=

# ---- LLM provider: gemini (FREE) | anthropic (paid, better quality) ----
LLM_PROVIDER=gemini

# Google AI Studio key — FREE, no card -> https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional paid upgrade for paying clients:
ANTHROPIC_API_KEY=
# Set true once Gemini paid billing is enabled (paid tier does not train on your data).
# Silences the boot warning about paid/regulated tenants on the free Gemini tier.
GEMINI_PAID=

# ---- Lead notifications (optional) ----
# Email lead alerts via Resend -> https://resend.com
RESEND_API_KEY=
FROM_EMAIL=Sona <leads@sona.app>
# Instant SMS lead alerts via Twilio (speed-to-lead) -> https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- Billing: Stripe -> https://dashboard.stripe.com/apikeys ----
# Secret key (sk_test_… in test mode). Billing is disabled if unset.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…) from Stripe → Developers → Webhooks (or `stripe listen`).
STRIPE_WEBHOOK_SECRET=
# Price IDs (price_…) for each paid plan, created in Stripe → Products.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
# Optional annual price IDs (enable the monthly/annual toggle in the dashboard).
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_ANNUAL=

# Server
# In prod set PORT to the host's port (Dockerfile defaults to 8080) and
# PUBLIC_BASE_URL to the real https origin — embed links, demo URLs, and Stripe
# redirects are all built from it, so it must match the live domain exactly.
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
